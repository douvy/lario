---
import Base from '../../layouts/Base.astro';
import { CategoryIcon, TierIcon } from '../../components/SpotIcon';
import { SPOTS } from '../../data/spots';
import { TIERS } from '../../data/tiers';

export function getStaticPaths() {
  return SPOTS.map((spot) => ({
    params: { id: spot.id },
    props: { spot },
  }));
}

const { spot } = Astro.props;
const tier = TIERS.find((t) => t.id === spot.tierId);

const title = `${spot.name} - Lake Como ${spot.categoryLabel} | Lake Como Guide`;
const description = `${spot.teaser} ${spot.notes.slice(0, 120)}...`;

const mapsLink = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${spot.lat},${spot.lng}`)}`;

// Related spots: same tier, different spot, max 3
const related = SPOTS
  .filter((s) => s.tierId === spot.tierId && s.id !== spot.id)
  .slice(0, 3);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': spot.kind === 'food' ? 'Restaurant' : 'TouristAttraction',
  name: spot.name,
  description: spot.notes,
  address: {
    '@type': 'PostalAddress',
    streetAddress: spot.address,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: spot.lat,
    longitude: spot.lng,
  },
  ...(spot.hours && { openingHours: spot.hours }),
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <div class="mx-auto min-h-dvh max-w-xl flex flex-col">
    <!-- Header -->
    <header class="px-6 pt-8 pb-6">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-[13px] text-muted hover:text-foreground transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to all spots
      </a>
    </header>

    <!-- Main Card -->
    <main class="px-6 flex-1">
      <article class="rounded-lg border border-border bg-surface overflow-hidden">
        <!-- Card Header -->
        <div class="px-5 py-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-center gap-2 text-sm text-muted">
              <TierIcon tierId={spot.tierId} className="text-ocean" />
              <span class="font-medium">{tier?.label}</span>
            </div>
            <span class="shrink-0 rounded border border-ocean/20 bg-ocean/5 px-1.5 py-0.5 font-mono text-[10px] text-ocean">
              {spot.driveBadge}
            </span>
          </div>

          <div class="mt-4 flex items-start gap-3">
            <CategoryIcon name={spot.categoryIcon} className="mt-1 text-ocean" />
            <div>
              <h1 class="font-display text-[28px] font-bold leading-tight tracking-tight text-foreground">
                {spot.name}
              </h1>
              <p class="mt-2 text-[15px] leading-relaxed text-muted">{spot.teaser}</p>
            </div>
          </div>
        </div>

        <!-- Card Body -->
        <div class="px-5 pb-5">
          <div class="border-t border-border pt-4">
            <!-- Meta Pills -->
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full bg-palm/15 px-2.5 py-1 text-[11px] text-palm">
                {spot.categoryLabel}
              </span>
              <span class="text-[11px] text-muted">{spot.driveDetails}</span>
              {spot.hours && (
                <span class="text-[11px] text-sand">{spot.hours}</span>
              )}
            </div>

            <!-- Notes -->
            <p class="mt-4 whitespace-pre-wrap text-[15px] leading-[1.7] text-muted">
              {spot.notes}
            </p>

            <!-- Address -->
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(spot.address)}`}
              target="_blank"
              rel="noopener"
              class="mt-4 block text-[13px] text-muted hover:text-foreground underline decoration-muted/30 hover:decoration-foreground/50 transition-colors"
            >
              {spot.address}
            </a>

            <!-- Actions -->
            <div class="mt-6 flex gap-3">
              <a
                href={mapsLink}
                class="flex-1 rounded-sm bg-ocean py-2.5 text-center text-[13px] tracking-tight text-white transition-all hover:bg-ocean-dim active:scale-[.99]"
                target="_blank"
                rel="noreferrer"
              >
                Navigate
              </a>
              <a
                href="/"
                class="flex-1 flex items-center justify-center rounded-sm border border-border bg-surface py-2.5 text-[13px] tracking-tight text-muted hover:bg-black/[0.02] hover:text-foreground transition-all active:scale-[.99]"
              >
                View all spots
              </a>
            </div>
          </div>
        </div>
      </article>

      <!-- Related Spots -->
      {related.length > 0 && (
        <section class="mt-10">
          <h2 class="text-[12px] uppercase tracking-wide text-muted/60 mb-4">
            More in {tier?.label}
          </h2>
          <div class="space-y-3">
            {related.map((r) => (
              <a
                href={`/spots/${r.id}`}
                class="group flex items-start gap-3 rounded-lg border border-border bg-surface px-4 py-3.5 transition-all hover:border-ocean/20 hover:bg-ocean/[0.02]"
              >
                <CategoryIcon name={r.categoryIcon} className="mt-0.5 text-ocean/70 group-hover:text-ocean transition-colors" />
                <div class="min-w-0 flex-1">
                  <div class="flex items-center justify-between gap-3">
                    <h3 class="font-display text-[15px] font-medium text-foreground truncate">
                      {r.name}
                    </h3>
                    <span class="shrink-0 text-[10px] text-muted/50 font-mono">
                      {r.driveBadge}
                    </span>
                  </div>
                  <p class="mt-1 text-[13px] text-muted/80 line-clamp-1">{r.teaser}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <!-- Footer -->
    <footer class="px-6 py-10 mt-12">
      <div class="flex items-center justify-between border-t border-border pt-6">
        <a href="/" class="group flex items-baseline gap-1.5">
          <span class="font-display text-[18px] font-bold tracking-tight text-foreground">Lake Como</span>
          <span class="text-[11px] text-muted/60 group-hover:text-ocean transition-colors">guide</span>
        </a>
        <p class="text-[11px] text-muted/40">
          Curated with love
        </p>
      </div>
    </footer>
  </div>
</Base>
